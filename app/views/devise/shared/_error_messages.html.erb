<% if resource.errors.any? %>
  <div id="error_explanation" class="rounded-[1.5rem] border border-mango/30 bg-mango/10 px-4 py-4 text-slate-900 shadow-sm">
    <h3 class="text-sm font-semibold uppercase tracking-[0.24em] text-mango">Needs Attention</h3>
    <p class="mt-2 text-base font-semibold">
      <%= I18n.t("errors.messages.not_saved",
                 count: resource.errors.count,
                 resource: resource.class.model_name.human.downcase) %>
    </p>
    <ul class="mt-3 space-y-2 text-sm leading-6 text-slate-700">
      <% resource.errors.full_messages.each do |message| %>
        <li class="flex items-start gap-2">
          <span class="mt-1 h-2 w-2 rounded-full bg-mango"></span>
          <span><%= message %></span>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
