<div class="flex flex-wrap gap-2 text-sm font-medium text-slate-700">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Log in", new_session_path(resource_name), class: "rounded-full border border-slate-200/80 bg-slate-50 px-4 py-2 transition hover:border-lagoon hover:text-slate-950" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Sign up", new_registration_path(resource_name), class: "rounded-full border border-slate-200/80 bg-slate-50 px-4 py-2 transition hover:border-lagoon hover:text-slate-950" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "rounded-full border border-slate-200/80 bg-slate-50 px-4 py-2 transition hover:border-lagoon hover:text-slate-950" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Resend confirmation", new_confirmation_path(resource_name), class: "rounded-full border border-slate-200/80 bg-slate-50 px-4 py-2 transition hover:border-lagoon hover:text-slate-950" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Unlock account", new_unlock_path(resource_name), class: "rounded-full border border-slate-200/80 bg-slate-50 px-4 py-2 transition hover:border-lagoon hover:text-slate-950" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= link_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), class: "rounded-full border border-slate-200/80 bg-slate-50 px-4 py-2 transition hover:border-lagoon hover:text-slate-950" %>
    <% end %>
  <% end %>
</div>
