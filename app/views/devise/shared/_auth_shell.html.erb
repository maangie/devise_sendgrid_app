<% highlights = Array(local_assigns[:highlights]).presence || [
  "Color-rich Rails UI",
  "Email confirmation ready",
  "Tailwind-powered forms"
] %>

<section class="mx-auto max-w-6xl px-6 pb-16 pt-8">
  <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
    <div class="relative overflow-hidden rounded-[2rem] bg-slate-950 px-8 py-10 text-white shadow-[0_35px_90px_-35px_rgba(15,23,42,0.8)] sm:px-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(255,122,69,0.28),_transparent_32%),radial-gradient(circle_at_bottom_right,_rgba(28,202,216,0.28),_transparent_30%)]"></div>
      <div class="absolute right-6 top-6 h-24 w-24 rounded-full border border-white/20"></div>
      <div class="absolute bottom-6 left-6 h-16 w-16 rounded-[1.5rem] bg-butter/20"></div>

      <div class="relative">
        <p class="text-xs font-semibold uppercase tracking-[0.35em] text-butter"><%= eyebrow %></p>
        <h2 class="mt-4 font-display text-4xl leading-tight sm:text-5xl"><%= title %></h2>
        <p class="mt-5 max-w-xl text-base leading-7 text-slate-200"><%= subtitle %></p>

        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          <% highlights.each do |highlight| %>
            <div class="rounded-[1.5rem] border border-white/10 bg-white/8 px-4 py-4 backdrop-blur-sm">
              <p class="text-sm font-medium leading-6 text-white"><%= highlight %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="rounded-[2rem] border border-white/80 bg-white/80 p-8 shadow-[0_30px_80px_-35px_rgba(15,23,42,0.45)] backdrop-blur-xl sm:p-10">
      <%= yield %>
    </div>
  </div>
</section>
