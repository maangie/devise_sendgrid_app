<%= render "devise/shared/auth_shell",
           eyebrow: "パスワード再設定",
           title: "パスワードをお忘れですか？",
           subtitle: "再設定リンクを送信して、アカウントへのアクセスをすばやく取り戻せます。",
           highlights: ["再設定メール送信", "Tailwind ベースのフォーム", "迷いにくい導線"] do %>
  <div class="space-y-6">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-mango">アクセスを回復</p>
      <p class="mt-3 text-sm leading-6 text-slate-600">登録済みのメールアドレス宛に、パスワード再設定の案内を送信します。</p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "text-sm font-semibold text-slate-800" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: app_input_classes, placeholder: "your@example.com" %>
      </div>

      <%= f.submit "再設定メールを送る", class: "#{app_primary_button_classes} w-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
<% end %>
