<%= render "devise/shared/auth_shell",
           eyebrow: "Security Refresh",
           title: "Change your password",
           subtitle: "Set a new password and keep the experience sharp from recovery to sign-in.",
           highlights: ["Protected reset token", "Clear password rules", "Fast return to login"] do %>
  <div class="space-y-6">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-mango">Choose New Credentials</p>
      <p class="mt-3 text-sm leading-6 text-slate-600">Use a fresh password you have not used elsewhere.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <div class="flex items-center justify-between gap-3">
          <%= f.label :password, "New password", class: "text-sm font-semibold text-slate-800" %>
          <% if @minimum_password_length %>
            <span class="text-xs uppercase tracking-[0.2em] text-slate-400"><%= @minimum_password_length %>+ chars</span>
          <% end %>
        </div>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: app_input_classes, placeholder: "New password" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm new password", class: "text-sm font-semibold text-slate-800" %>
        <%= f.password_field :password_confirmation, autocomplete: "off", class: app_input_classes, placeholder: "Repeat new password" %>
      </div>

      <%= f.submit "Change my password", class: "#{app_primary_button_classes} w-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
<% end %>
