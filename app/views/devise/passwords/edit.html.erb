<%= render "devise/shared/auth_shell",
           eyebrow: "認証情報の更新",
           title: "パスワード変更",
           subtitle: "新しいパスワードを設定して、再設定フローからそのまま安全に戻れます。",
           highlights: ["保護された再設定トークン", "分かりやすいルール表示", "ログインへの復帰が速い"] do %>
  <div class="space-y-6">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-mango">新しい認証情報</p>
      <p class="mt-3 text-sm leading-6 text-slate-600">他のサービスと使い回していない、新しいパスワードを設定してください。</p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <div class="flex items-center justify-between gap-3">
          <%= f.label :password, "新しいパスワード", class: "text-sm font-semibold text-slate-800" %>
          <% if @minimum_password_length %>
            <span class="text-xs uppercase tracking-[0.2em] text-slate-400"><%= @minimum_password_length %>文字以上</span>
          <% end %>
        </div>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: app_input_classes, placeholder: "新しいパスワード" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "text-sm font-semibold text-slate-800" %>
        <%= f.password_field :password_confirmation, autocomplete: "off", class: app_input_classes, placeholder: "新しいパスワードを再入力" %>
      </div>

      <%= f.submit "パスワードを変更する", class: "#{app_primary_button_classes} w-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
<% end %>
