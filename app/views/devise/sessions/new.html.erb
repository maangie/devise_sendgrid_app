<%= render "devise/shared/auth_shell",
           eyebrow: "おかえりなさい",
           title: "ログイン",
           subtitle: "日本語化された認証画面からログインして、アカウント管理画面へ戻れます。",
           highlights: ["分かりやすいログイン導線", "カラフルなランディング", "アカウント操作を整理"] do %>
  <div class="space-y-6">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-mango">アカウントへアクセス</p>
      <p class="mt-3 text-sm leading-6 text-slate-600">確認済みのメールアドレスでログインして、更新済みのホーム画面へ進みます。</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, class: "text-sm font-semibold text-slate-800" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: app_input_classes, placeholder: "your@example.com" %>
      </div>

      <div>
        <%= f.label :password, class: "text-sm font-semibold text-slate-800" %>
        <%= f.password_field :password, autocomplete: "current-password", class: app_input_classes, placeholder: "パスワードを入力" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-3 rounded-[1.25rem] border border-slate-200/80 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-700">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-lagoon focus:ring-lagoon" %>
          <span>この端末でログイン状態を保持する</span>
        </label>
      <% end %>

      <%= f.submit "ログインする", class: "#{app_primary_button_classes} w-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
<% end %>
