<%= render "devise/shared/auth_shell",
           eyebrow: "Unlock Flow",
           title: "Resend unlock instructions",
           subtitle: "If your account is locked, ship a fresh unlock email without dropping the stronger visual language.",
           highlights: ["Account recovery", "Consistent UI shell", "Fast path back in"] do %>
  <div class="space-y-6">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-mango">Unlock Account</p>
      <p class="mt-3 text-sm leading-6 text-slate-600">Enter your email and we'll send new instructions so you can regain access.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "text-sm font-semibold text-slate-800" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: app_input_classes, placeholder: "you@example.com" %>
      </div>

      <%= f.submit "Resend unlock instructions", class: "#{app_primary_button_classes} w-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
<% end %>
