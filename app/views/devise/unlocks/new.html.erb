<%= render "devise/shared/auth_shell",
           eyebrow: "ロック解除",
           title: "ロック解除メールを再送",
           subtitle: "アカウントがロックされていても、新しい案内メールを送って復帰できます。",
           highlights: ["アカウント回復", "統一された UI", "復帰までの導線を短く"] do %>
  <div class="space-y-6">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-mango">アカウントのロック解除</p>
      <p class="mt-3 text-sm leading-6 text-slate-600">メールアドレスを入力すると、アクセス再開のための案内を送信します。</p>
    </div>

    <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "text-sm font-semibold text-slate-800" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: app_input_classes, placeholder: "your@example.com" %>
      </div>

      <%= f.submit "ロック解除メールを送る", class: "#{app_primary_button_classes} w-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
<% end %>
