<%= render "devise/shared/auth_shell",
           eyebrow: "設定画面",
           title: "アカウント設定",
           subtitle: "メールアドレスやパスワードを更新しながら、確認状態や主要操作も一つの画面で管理できます。",
           highlights: ["プロフィール更新", "安全なパスワード変更", "主要操作を集約"] do %>
  <div class="space-y-6">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-mango">アカウント設定</p>
      <p class="mt-3 text-sm leading-6 text-slate-600">メールアドレスだけを変更する場合は、パスワード欄を空のままにしてください。</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "text-sm font-semibold text-slate-800" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: app_input_classes %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="rounded-[1.5rem] border border-butter/40 bg-butter/15 px-4 py-3 text-sm text-slate-800">
          <strong><%= resource.unconfirmed_email %></strong> での確認待ちです。
        </div>
      <% end %>

      <div>
        <div class="flex items-center justify-between gap-3">
          <%= f.label :password, class: "text-sm font-semibold text-slate-800" %>
          <% if @minimum_password_length %>
            <span class="text-xs uppercase tracking-[0.2em] text-slate-400"><%= @minimum_password_length %>文字以上</span>
          <% end %>
        </div>
        <p class="mt-1 text-xs uppercase tracking-[0.2em] text-slate-400">変更しない場合は空欄のままで大丈夫です</p>
        <%= f.password_field :password, autocomplete: "new-password", class: app_input_classes, placeholder: "新しいパスワード" %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "text-sm font-semibold text-slate-800" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: app_input_classes, placeholder: "新しいパスワードを再入力" %>
      </div>

      <div>
        <%= f.label :current_password, class: "text-sm font-semibold text-slate-800" %>
        <p class="mt-1 text-xs uppercase tracking-[0.2em] text-slate-400">変更を保存するために必要です</p>
        <%= f.password_field :current_password, autocomplete: "current-password", class: app_input_classes, placeholder: "現在のパスワード" %>
      </div>

      <%= f.submit "更新する", class: "#{app_primary_button_classes} w-full" %>
    <% end %>

    <div class="flex flex-wrap items-center gap-3">
      <%= link_to "ホームへ戻る", root_path, class: app_secondary_button_classes %>
      <%= button_to "アカウントを削除", registration_path(resource_name), method: :delete, class: "inline-flex items-center justify-center rounded-full border border-mango/40 bg-mango/10 px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-mango hover:text-white", form_class: "inline-block" %>
    </div>
  </div>
<% end %>
