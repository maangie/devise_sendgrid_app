<%= render "devise/shared/auth_shell",
           eyebrow: "新規アカウント",
           title: "新規登録",
           subtitle: "デモ用のアカウントを作成して、Devise のメール確認フローを日本語 UI からそのまま試せます。",
           highlights: ["Tailwind ベースの画面", "メール確認フロー対応", "Rails 8 / Ruby 4 対応"] do %>
  <div class="space-y-6">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-mango">プロフィール作成</p>
      <p class="mt-3 text-sm leading-6 text-slate-600">確認できるメールアドレスを入力してください。登録後に確認リンク付きメールが発行されます。</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "text-sm font-semibold text-slate-800" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: app_input_classes, placeholder: "your@example.com" %>
      </div>

      <div>
        <div class="flex items-center justify-between gap-3">
          <%= f.label :password, class: "text-sm font-semibold text-slate-800" %>
          <% if @minimum_password_length %>
            <span class="text-xs uppercase tracking-[0.2em] text-slate-400"><%= @minimum_password_length %>文字以上</span>
          <% end %>
        </div>
        <%= f.password_field :password, autocomplete: "new-password", class: app_input_classes, placeholder: "安全なパスワードを入力" %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "text-sm font-semibold text-slate-800" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: app_input_classes, placeholder: "同じパスワードを再入力" %>
      </div>

      <%= f.submit "登録する", class: "#{app_primary_button_classes} w-full" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
<% end %>
